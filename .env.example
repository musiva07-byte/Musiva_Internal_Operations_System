# Supabase public project configuration.
# Safe to expose in browser bundles. Do not add service role keys to this app.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this through NEXT_PUBLIC_ or client components.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: used when deploying admin.musiva.com separately from musiva.com.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_DOMAIN=admin.musiva.com

# Netlify-only, optional. Helps prevent client-side errors during deploy swaps.
NETLIFY_NEXT_SKEW_PROTECTION=true
